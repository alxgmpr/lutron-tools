  "endianness_rules": {
    "description": "All SOURCE device IDs are stored little-endian. Only TARGET IDs are big-endian.",
    "BTN_*": "Device ID (source) stored little-endian - read bytes reversed to get label",
    "STATE_RPT": "Device ID (source) stored little-endian - read bytes reversed to get label",
    "LEVEL": "Source ID stored little-endian, Target ID stored big-endian",
    "UNPAIR": "Bridge zone (source) stored little-endian, Target ID stored big-endian",
    "PAIRING": "Device ID (source) stored little-endian",
    "BEACON": "Load ID stored little-endian"
  },
  "format_byte_discrimination": {
    "description": "Byte[7] distinguishes packet subtypes for 0x81-0x83 packets",
    "0x08": "STATE_RPT (dimmer reporting its level)",
    "0x09": "UNPAIR_PREPARE (phase 1 of unpair)",
    "0x0C": "UNPAIR (phase 2 unpair flood)",
    "0x0E": "LEVEL (bridge setting device level)"
  }
