        "button_code": "0x02",
        "action": "PRESS",
        "action_code": "0x00"
      },
      "field_bytes": {
        "type": {"offset": 0, "bytes": "88"},
        "sequence": {"offset": 1, "bytes": "00"},
        "device_id": {"offset": 2, "bytes": "8D E6 95 05", "note": "Stored reversed, displayed as 0595E68D"},
        "button": {"offset": 10, "bytes": "02"},
        "action": {"offset": 11, "bytes": "00"}
      }
    },
