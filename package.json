{
  "name": "lutron-tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@11.6.1",
  "scripts": {
    "cli:nucleo": "npx tsx cli/nucleo.ts",
    "codegen": "npx tsx tools/codegen.ts",
    "codegen:check": "npm run codegen && clang-format -i firmware/src/cca/cca_generated.h firmware/src/ccx/ccx_generated.h && git -c core.fileMode=false diff --exit-code -- firmware/src/cca/cca_generated.h firmware/src/ccx/ccx_generated.h",
    "leap:dump": "npx tsx tools/leap/leap-dump.ts",
    "cca:ota-tx": "npx tsx tools/cca/ota-tx.ts",
    "gather-presets": "npx tsx tools/designer/gather-presets.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "test:ts": "node --import tsx --test test/**/*.test.ts",
    "test:firmware": "make -C firmware test",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:ts && npm run test:firmware",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "@serialport/parser-readline": "^13.0.0",
    "cbor-x": "^1",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "serialport": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
