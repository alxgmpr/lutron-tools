{
  "name": "lutron-tools",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.6.1",
  "scripts": {
    "codegen": "bun run tools/codegen.ts",
    "codegen:check": "npm run codegen && git diff --exit-code -- firmware/src/cca/cca_generated.h firmware/src/ccx/ccx_generated.h",
    "cca:owt": "bun run tools/cca-owt-analyze.ts",
    "ccx:sniff": "bun run tools/ccx-sniffer.ts",
    "ccx:analyze": "bun run tools/ccx-analyzer.ts",
    "ccx:send": "bun run tools/ccx-send.ts",
    "ccx:coap": "bun run tools/ccx-coap-send.ts",
    "ccx:watch": "bun run tools/ccx-program-watch.ts --live",
    "ccx:diff": "bun run tools/ccx-program-diff.ts",
    "cca:tune-bench": "python3 tools/cca-tune-bench.py",
    "leap:dump": "bun run tools/leap-dump.ts",
    "gather-presets": "npx tsx tools/gather-presets.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "test:ts": "node --import tsx --test test/**/*.test.ts",
    "test:firmware": "make -C firmware test",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "npm run test:ts && npm run test:firmware",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "@serialport/parser-readline": "^13.0.0",
    "cbor-x": "^1",
    "serialport": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/node": "^24.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
