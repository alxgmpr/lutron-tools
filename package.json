{
  "name": "lutron-tools",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "web",
    "backend"
  ],
  "scripts": {
    "predev": "(lsof -ti :5001 | xargs kill -9; lsof -ti :9433 | xargs kill -9; lsof -ti :5173 | xargs kill -9) 2>/dev/null || true",
    "dev": "concurrently -n backend,web -c blue,green \"npm run dev -w backend\" \"npm run dev -w web\"",
    "build": "npm run build -w web",
    "test": "npm run test -w web",
    "codegen": "cargo run --manifest-path cca/Cargo.toml --release -- codegen",
    "cca": "cargo run --manifest-path cca/Cargo.toml --release --",
    "ccx:sniff": "bun run tools/ccx-sniffer.ts",
    "ccx:analyze": "bun run tools/ccx-analyzer.ts",
    "leap:dump": "bun run tools/leap-dump.ts",
    "clean": "rm -rf node_modules web/node_modules backend/node_modules"
  },
  "dependencies": {
    "cbor-x": "^1"
  },
  "devDependencies": {
    "concurrently": "^9",
    "shadcn": "^3.8.3"
  }
}
