{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lutron CCA Packet Test Fixtures",
  "type": "object",
  "required": ["version", "packets"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string"
    },
    "packets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/packet"
      }
    },
    "button_codes": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "action_codes": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "packet_types": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "endianness_rules": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "format_byte_discrimination": {
      "type": "object"
    }
  },
  "definitions": {
    "packet": {
      "type": "object",
      "required": ["id", "name", "category", "raw_bytes", "expected"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique test case identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable test name"
        },
        "category": {
          "type": "string",
          "enum": ["button", "state_report", "level", "unpair", "unpair_prepare", "pairing", "beacon"]
        },
        "raw_bytes": {
          "type": "string",
          "pattern": "^([0-9A-Fa-f]{2}\\s?)+$",
          "description": "Space-separated hex bytes"
        },
        "notes": {
          "type": "string"
        },
        "expected": {
          "$ref": "#/definitions/expected_values"
        },
        "field_bytes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/field_definition"
          }
        }
      }
    },
    "expected_values": {
      "type": "object",
      "properties": {
        "packet_type": {"type": "string"},
        "packet_type_byte": {"type": "string", "pattern": "^0x[0-9A-Fa-f]{2}$"},
        "sequence": {"type": "integer", "minimum": 0, "maximum": 255},
        "device_id": {"type": "string", "pattern": "^[0-9A-Fa-f]{8}$"},
        "device_id_endian": {"type": "string", "enum": ["big", "little"]},
        "source_id": {"type": "string", "pattern": "^[0-9A-Fa-f]{8}$"},
        "source_id_endian": {"type": "string", "enum": ["big", "little"]},
        "target_id": {"type": "string", "pattern": "^[0-9A-Fa-f]{8}$"},
        "target_id_endian": {"type": "string", "enum": ["big", "little"]},
        "level": {"type": "integer", "minimum": 0, "maximum": 100},
        "button": {"type": "string"},
        "button_code": {"type": "string", "pattern": "^0x[0-9A-Fa-f]{2}$"},
        "action": {"type": "string", "enum": ["PRESS", "RELEASE", "SAVE"]},
        "action_code": {"type": "string", "pattern": "^0x[0-9A-Fa-f]{2}$"},
        "format_byte": {"type": "string", "pattern": "^0x[0-9A-Fa-f]{2}$"},
        "cmd_bytes": {"type": "string"},
        "crc_valid": {"type": "boolean"},
        "crc_hex": {"type": "string", "pattern": "^[0-9A-Fa-f]{4}$"}
      },
      "required": ["packet_type"]
    },
    "field_definition": {
      "type": "object",
      "required": ["offset", "bytes"],
      "properties": {
        "offset": {"type": "integer", "minimum": 0},
        "bytes": {"type": "string"},
        "note": {"type": "string"}
      }
    }
  }
}
