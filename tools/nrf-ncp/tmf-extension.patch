diff --git a/src/ncp/ncp_tmf_ext.cpp b/src/ncp/ncp_tmf_ext.cpp
new file mode 100644
index 0000000..d8ea081
--- /dev/null
+++ b/src/ncp/ncp_tmf_ext.cpp
@@ -0,0 +1,452 @@
+/*
+ * Lutron vendor Spinel extension — TMF toolkit.
+ */
+#include "ncp_tmf_ext.hpp"
+
+#include <new>
+#include <string.h>
+
+#include <openthread/thread.h>
+#include <openthread/thread_ftd.h>
+
+#include "common/code_utils.hpp"
+#include "ncp/ncp_base.hpp"
+
+namespace ot {
+namespace Ncp {
+
+namespace {
+
+// Singleton pointer. Used only by this TU so it has internal linkage.
+NcpTmfExtension *gNcpTmfExt = nullptr;
+
+// Bit layout for the flags byte emitted per entry in the neighbor and child
+// tables. Kept in-sync with the host-side decoder.
+constexpr uint8_t kNeighborFlagIsChild          = 0x01;
+constexpr uint8_t kNeighborFlagRxOnWhenIdle     = 0x02;
+constexpr uint8_t kNeighborFlagFullThreadDevice = 0x04;
+constexpr uint8_t kNeighborFlagSecureDataReq    = 0x08; // reserved; not populated in this OT rev
+constexpr uint8_t kNeighborFlagFullNetworkData  = 0x10;
+
+// Reason codes emitted with DIAG_GET_DONE.
+constexpr uint8_t kDoneReasonTimerElapsed = 0;
+constexpr uint8_t kDoneReasonError        = 1;
+
+// Stack scratch for otMessageRead chunks in the DIAG_GET_RESPONSE loop.
+constexpr uint16_t kReadChunkBytes = 64;
+
+} // namespace
+
+NcpTmfExtension::NcpTmfExtension(Instance &aInstance, NcpBase &aNcpBase)
+    : mNcpBase(aNcpBase)
+    , mInstance(aInstance)
+    , mInFlight(false)
+    , mResponderCount(0)
+    , mTimer(aInstance, NcpTmfExtension::HandleTimerTrampoline, this)
+{
+    gNcpTmfExt = this;
+}
+
+// ---------------------------------------------------------------------------
+// Static trampolines
+// ---------------------------------------------------------------------------
+
+void NcpTmfExtension::HandleDiagGetResponseTrampoline(otError              aError,
+                                                      otMessage           *aMessage,
+                                                      const otMessageInfo *aMessageInfo,
+                                                      void                *aContext)
+{
+    static_cast<NcpTmfExtension *>(aContext)->HandleDiagGetResponse(aError, aMessage, aMessageInfo);
+}
+
+void NcpTmfExtension::HandleTimerTrampoline(Timer &aTimer)
+{
+    static_cast<NcpTmfExtension *>(static_cast<TimerMilliContext &>(aTimer).GetContext())->HandleTimer();
+}
+
+// ---------------------------------------------------------------------------
+// Neighbor-table handler (0x3C04)
+// ---------------------------------------------------------------------------
+
+otError NcpTmfExtension::HandleGetNeighborTable(void)
+{
+    // Single-pass: buffer entries into a local stack array, then emit count +
+    // buffered bytes so the count is always consistent with the payload.
+    // A two-pass design would race if a neighbor joined or left between
+    // the count pass and the emit pass. Cap at 32 entries — matches
+    // OPENTHREAD_CONFIG_MAX_ROUTERS and keeps buffer well under a typical
+    // task stack.
+    static constexpr uint8_t  kMaxEntries    = 32;
+    static constexpr uint16_t kBytesPerEntry = 17;
+    static constexpr uint16_t kBufferSize    = static_cast<uint16_t>(kMaxEntries) * kBytesPerEntry;
+
+    uint8_t  buf[kBufferSize];
+    uint16_t pos   = 0;
+    uint8_t  count = 0;
+
+    otNeighborInfoIterator iter = OT_NEIGHBOR_INFO_ITERATOR_INIT;
+    otNeighborInfo         info;
+
+    while (otThreadGetNextNeighborInfo(&mInstance, &iter, &info) == OT_ERROR_NONE)
+    {
+        if (count >= kMaxEntries)
+        {
+            break; // soft cap — drop extras rather than overflow
+        }
+
+        // EUI-64 (8 bytes, network order per Spinel convention)
+        memcpy(&buf[pos], info.mExtAddress.m8, 8);
+        pos = static_cast<uint16_t>(pos + 8);
+
+        // RLOC16 (LE)
+        buf[pos++] = static_cast<uint8_t>(info.mRloc16 & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mRloc16 >> 8) & 0xFF);
+
+        // Age in seconds (LE uint32)
+        buf[pos++] = static_cast<uint8_t>(info.mAge & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mAge >> 8) & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mAge >> 16) & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mAge >> 24) & 0xFF);
+
+        // Signed int8 RSSI fields — two's-complement-preserving cast
+        buf[pos++] = static_cast<uint8_t>(info.mAverageRssi);
+        buf[pos++] = static_cast<uint8_t>(info.mLastRssi);
+
+        // Flags: mSecureDataRequest is not exposed on otNeighborInfo in this
+        // OT rev, so kNeighborFlagSecureDataReq is reserved and always 0.
+        uint8_t flags = 0;
+        if (info.mIsChild)
+        {
+            flags |= kNeighborFlagIsChild;
+        }
+        if (info.mRxOnWhenIdle)
+        {
+            flags |= kNeighborFlagRxOnWhenIdle;
+        }
+        if (info.mFullThreadDevice)
+        {
+            flags |= kNeighborFlagFullThreadDevice;
+        }
+        if (info.mFullNetworkData)
+        {
+            flags |= kNeighborFlagFullNetworkData;
+        }
+        buf[pos++] = flags;
+
+        count++;
+    }
+
+    otError error = OT_ERROR_NONE;
+    SuccessOrExit(error = mNcpBase.mEncoder.WriteUint8(count));
+    SuccessOrExit(error = mNcpBase.mEncoder.WriteData(buf, pos));
+
+exit:
+    return error;
+}
+
+// ---------------------------------------------------------------------------
+// Child-table handler (0x3C05)
+// ---------------------------------------------------------------------------
+
+otError NcpTmfExtension::HandleGetChildTable(void)
+{
+    // Same single-pass pattern as HandleGetNeighborTable — see comment there.
+    // 32 is the MLE upper bound for children in typical OT configs.
+    static constexpr uint8_t  kMaxEntries    = 32;
+    static constexpr uint16_t kBytesPerEntry = 21;
+    static constexpr uint16_t kBufferSize    = static_cast<uint16_t>(kMaxEntries) * kBytesPerEntry;
+
+    uint8_t  buf[kBufferSize];
+    uint16_t pos   = 0;
+    uint8_t  count = 0;
+
+    otChildInfo info;
+    for (uint16_t i = 0;; i++)
+    {
+        if (otThreadGetChildInfoByIndex(&mInstance, i, &info) != OT_ERROR_NONE)
+        {
+            break; // end of child table
+        }
+        if (info.mRloc16 == 0xFFFE)
+        {
+            continue; // sentinel entry; skip
+        }
+        if (count >= kMaxEntries)
+        {
+            break;
+        }
+
+        memcpy(&buf[pos], info.mExtAddress.m8, 8);
+        pos = static_cast<uint16_t>(pos + 8);
+
+        buf[pos++] = static_cast<uint8_t>(info.mRloc16 & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mRloc16 >> 8) & 0xFF);
+
+        buf[pos++] = static_cast<uint8_t>(info.mTimeout & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mTimeout >> 8) & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mTimeout >> 16) & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mTimeout >> 24) & 0xFF);
+
+        buf[pos++] = static_cast<uint8_t>(info.mAge & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mAge >> 8) & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mAge >> 16) & 0xFF);
+        buf[pos++] = static_cast<uint8_t>((info.mAge >> 24) & 0xFF);
+
+        buf[pos++] = static_cast<uint8_t>(info.mAverageRssi);
+        buf[pos++] = static_cast<uint8_t>(info.mLastRssi);
+
+        // otChildInfo exposes no mIsChild (it's implicitly true) and no
+        // mSecureDataRequest in this OT rev. kNeighborFlagIsChild and
+        // kNeighborFlagSecureDataReq are therefore not set here.
+        uint8_t flags = 0;
+        if (info.mRxOnWhenIdle)
+        {
+            flags |= kNeighborFlagRxOnWhenIdle;
+        }
+        if (info.mFullThreadDevice)
+        {
+            flags |= kNeighborFlagFullThreadDevice;
+        }
+        if (info.mFullNetworkData)
+        {
+            flags |= kNeighborFlagFullNetworkData;
+        }
+        buf[pos++] = flags;
+
+        count++;
+    }
+
+    otError error = OT_ERROR_NONE;
+    SuccessOrExit(error = mNcpBase.mEncoder.WriteUint8(count));
+    SuccessOrExit(error = mNcpBase.mEncoder.WriteData(buf, pos));
+
+exit:
+    return error;
+}
+
+// ---------------------------------------------------------------------------
+// DIAG_RESET_REQUEST (0x3C03) — fire-and-forget
+// ---------------------------------------------------------------------------
+
+otError NcpTmfExtension::HandleSetDiagResetRequest(const uint8_t *aArg, uint16_t aLen)
+{
+    if (aLen < 17)
+    {
+        return OT_ERROR_PARSE;
+    }
+
+    otIp6Address dst;
+    memcpy(dst.mFields.m8, aArg, 16);
+
+    uint8_t tlvCount = aArg[16];
+    if (tlvCount == 0 || tlvCount > TMF_EXT_MAX_TLV_TYPES)
+    {
+        return OT_ERROR_PARSE;
+    }
+    if (aLen != static_cast<uint16_t>(17u + tlvCount))
+    {
+        return OT_ERROR_PARSE;
+    }
+
+    return otThreadSendDiagnosticReset(&mInstance, &dst, &aArg[17], tlvCount);
+}
+
+// ---------------------------------------------------------------------------
+// DIAG_GET_REQUEST (0x3C00)
+// ---------------------------------------------------------------------------
+
+otError NcpTmfExtension::HandleSetDiagGetRequest(const uint8_t *aArg, uint16_t aLen)
+{
+    if (mInFlight)
+    {
+        return OT_ERROR_BUSY;
+    }
+
+    if (aLen < 17)
+    {
+        return OT_ERROR_PARSE;
+    }
+
+    otIp6Address dst;
+    memcpy(dst.mFields.m8, aArg, 16);
+
+    uint8_t tlvCount = aArg[16];
+    if (tlvCount == 0 || tlvCount > TMF_EXT_MAX_TLV_TYPES)
+    {
+        return OT_ERROR_PARSE;
+    }
+    if (aLen != static_cast<uint16_t>(17u + tlvCount))
+    {
+        return OT_ERROR_PARSE;
+    }
+
+    otError err = otThreadSendDiagnosticGet(&mInstance, &dst, &aArg[17], tlvCount,
+                                            &NcpTmfExtension::HandleDiagGetResponseTrampoline, this);
+    if (err != OT_ERROR_NONE)
+    {
+        return err;
+    }
+
+    mInFlight       = true;
+    mResponderCount = 0;
+    mTimer.Start(TMF_EXT_DIAG_GET_TIMEOUT_MS);
+
+    return OT_ERROR_NONE;
+}
+
+// ---------------------------------------------------------------------------
+// DIAG_GET_RESPONSE emitter (async, 0x3C01)
+// ---------------------------------------------------------------------------
+
+// Safe single-threaded: OT's NCP runs all callbacks (Spinel receive, OT timer,
+// diag-get response) serially on the same task, so mResponderCount++ needs no
+// atomic/lock.
+void NcpTmfExtension::HandleDiagGetResponse(otError aError, otMessage *aMessage, const otMessageInfo *aMessageInfo)
+{
+    if (aError != OT_ERROR_NONE || aMessage == nullptr || aMessageInfo == nullptr)
+    {
+        return;
+    }
+
+    uint16_t offset = otMessageGetOffset(aMessage);
+    uint16_t msgLen = otMessageGetLength(aMessage);
+    uint16_t tlvLen = (msgLen > offset) ? static_cast<uint16_t>(msgLen - offset) : 0;
+
+    // Cap payload so the full frame fits comfortably in the Spinel buffer.
+    // Truncation is encoded as the high bit of the length field.
+    bool     truncated = false;
+    uint16_t emit      = tlvLen;
+    if (emit > TMF_EXT_DIAG_GET_RESPONSE_MAX_BYTES)
+    {
+        emit      = TMF_EXT_DIAG_GET_RESPONSE_MAX_BYTES;
+        truncated = true;
+    }
+
+    const uint8_t  header   = SPINEL_HEADER_FLAG | SPINEL_HEADER_TX_NOTIFICATION_IID;
+    const uint16_t lenField = static_cast<uint16_t>(emit | (truncated ? 0x8000u : 0u));
+
+    otError error = OT_ERROR_NONE;
+
+    SuccessOrExit(error = mNcpBase.mEncoder.BeginFrame(header, SPINEL_CMD_PROP_VALUE_INSERTED,
+                                                       SPINEL_PROP_VENDOR_DIAG_GET_RESPONSE));
+    SuccessOrExit(error = mNcpBase.mEncoder.WriteData(aMessageInfo->mPeerAddr.mFields.m8, 16));
+    SuccessOrExit(error = mNcpBase.mEncoder.WriteUint16(lenField));
+
+    // Stream TLV bytes directly from the message in chunks.
+    {
+        uint8_t  chunk[kReadChunkBytes];
+        uint16_t remaining = emit;
+        uint16_t readFrom  = offset;
+        while (remaining > 0)
+        {
+            uint16_t n = (remaining < sizeof(chunk)) ? remaining : static_cast<uint16_t>(sizeof(chunk));
+            if (otMessageRead(aMessage, readFrom, chunk, n) != n)
+            {
+                // Partial read would leave the emitted bytes short of the
+                // already-written tlv_len. Bail; the Spinel encoder discards
+                // the in-progress frame at the next BeginFrame so the host
+                // won't see a corrupt record. The caller sees NOMEM.
+                error = OT_ERROR_FAILED;
+                ExitNow();
+            }
+            SuccessOrExit(error = mNcpBase.mEncoder.WriteData(chunk, n));
+            readFrom  = static_cast<uint16_t>(readFrom + n);
+            remaining = static_cast<uint16_t>(remaining - n);
+        }
+    }
+    SuccessOrExit(error = mNcpBase.mEncoder.EndFrame());
+
+    mResponderCount++;
+
+exit:
+    if (error != OT_ERROR_NONE)
+    {
+        mNcpBase.mChangedPropsSet.AddLastStatus(SPINEL_STATUS_NOMEM);
+        mNcpBase.mUpdateChangedPropsTask.Post();
+    }
+}
+
+// ---------------------------------------------------------------------------
+// Completion timer — emits DIAG_GET_DONE (0x3C02) and clears in-flight state
+// ---------------------------------------------------------------------------
+
+void NcpTmfExtension::HandleTimer(void)
+{
+    const uint8_t header = SPINEL_HEADER_FLAG | SPINEL_HEADER_TX_NOTIFICATION_IID;
+    otError       error  = OT_ERROR_NONE;
+
+    SuccessOrExit(error = mNcpBase.mEncoder.BeginFrame(header, SPINEL_CMD_PROP_VALUE_INSERTED,
+                                                       SPINEL_PROP_VENDOR_DIAG_GET_DONE));
+    SuccessOrExit(error = mNcpBase.mEncoder.WriteUint8(kDoneReasonTimerElapsed));
+    SuccessOrExit(error = mNcpBase.mEncoder.WriteUint16(mResponderCount)); // LE
+    SuccessOrExit(error = mNcpBase.mEncoder.EndFrame());
+
+exit:
+    if (error != OT_ERROR_NONE)
+    {
+        mNcpBase.mChangedPropsSet.AddLastStatus(SPINEL_STATUS_NOMEM);
+        mNcpBase.mUpdateChangedPropsTask.Post();
+    }
+
+    mInFlight = false;
+}
+
+// ---------------------------------------------------------------------------
+// Template specializations for vendor properties dispatched via NcpBase
+// ---------------------------------------------------------------------------
+
+template <> otError NcpBase::HandlePropertyGet<SPINEL_PROP_VENDOR_NEIGHBOR_TABLE>(void)
+{
+    return (gNcpTmfExt != nullptr) ? gNcpTmfExt->HandleGetNeighborTable() : OT_ERROR_INVALID_STATE;
+}
+
+template <> otError NcpBase::HandlePropertyGet<SPINEL_PROP_VENDOR_CHILD_TABLE>(void)
+{
+    return (gNcpTmfExt != nullptr) ? gNcpTmfExt->HandleGetChildTable() : OT_ERROR_INVALID_STATE;
+}
+
+template <> otError NcpBase::HandlePropertySet<SPINEL_PROP_VENDOR_DIAG_GET_REQUEST>(void)
+{
+    const uint8_t *data    = nullptr;
+    uint16_t       dataLen = 0;
+    otError        error   = mDecoder.ReadData(data, dataLen);
+
+    if (error == OT_ERROR_NONE)
+    {
+        error = (gNcpTmfExt != nullptr) ? gNcpTmfExt->HandleSetDiagGetRequest(data, dataLen) : OT_ERROR_INVALID_STATE;
+    }
+
+    return error;
+}
+
+template <> otError NcpBase::HandlePropertySet<SPINEL_PROP_VENDOR_DIAG_RESET_REQUEST>(void)
+{
+    const uint8_t *data    = nullptr;
+    uint16_t       dataLen = 0;
+    otError        error   = mDecoder.ReadData(data, dataLen);
+
+    if (error == OT_ERROR_NONE)
+    {
+        error = (gNcpTmfExt != nullptr) ? gNcpTmfExt->HandleSetDiagResetRequest(data, dataLen) : OT_ERROR_INVALID_STATE;
+    }
+
+    return error;
+}
+
+} // namespace Ncp
+} // namespace ot
+
+// ---------------------------------------------------------------------------
+// C init called from NcpBase constructor patch
+// ---------------------------------------------------------------------------
+
+extern "C" void NcpTmfExtensionInit(ot::Ncp::NcpBase *aNcpBase)
+{
+    // Static storage + placement-new: we need exactly one NcpTmfExtension for
+    // the process lifetime and cannot rely on a heap in the NCP firmware.
+    // OT_DEFINE_ALIGNED_VAR guarantees alignment suitable for the embedded
+    // TimerMilliContext (pointer-aligned members) — see the reference use
+    // in openthread/src/ncp/example_vendor_hook.cpp.
+    static OT_DEFINE_ALIGNED_VAR(sStorage, sizeof(ot::Ncp::NcpTmfExtension), uint64_t);
+    new (&sStorage) ot::Ncp::NcpTmfExtension(aNcpBase->GetInstance(), *aNcpBase);
+}
