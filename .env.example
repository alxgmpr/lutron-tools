# Lutron Tools Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# Processor IPs
RA3_HOST=10.x.x.x
CASETA_HOST=10.x.x.x
NUCLEO_HOST=10.x.x.x
DESIGNER_VM_HOST=10.x.x.x

# Designer VM credentials
DESIGNER_VM_USER=user
DESIGNER_VM_PASS=pass

# Thread network parameters (from LEAP /link endpoint)
THREAD_CHANNEL=25
THREAD_PANID=0x0000
THREAD_XPANID=0000000000000000
THREAD_MASTER_KEY=00000000000000000000000000000000
